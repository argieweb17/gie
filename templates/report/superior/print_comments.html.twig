<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SEF Comments — {{ faculty.fullName }}</title>
    <style>
        /* ══════════════════════════════════════════════
           PRINT LAYOUT — Superior Evaluation Comments
           Matches Official NORSU QUAMC format.
           ══════════════════════════════════════════════ */

        @page {
            size: A4 portrait;
            margin: 12mm 16mm 12mm 16mm;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
            padding: 20px 36px;
            color: #000;
            font-size: 11px;
            line-height: 1.35;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        /* ── Letterhead ── */
        .letterhead {
            text-align: center;
            margin-bottom: 10px;
        }
        .letterhead img {
            max-width: 100%;
            height: auto;
        }

        /* ── Title Block ── */
        .title-block {
            text-align: center;
            margin-bottom: 16px;
        }
        .title-block h2 {
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 3px;
        }

        /* ── Faculty Info Table ── */
        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 14px;
            font-size: 11px;
        }
        .info-table td {
            padding: 2px 4px;
            border: none;
            vertical-align: bottom;
        }
        .info-table .lbl {
            font-weight: 400;
            white-space: nowrap;
        }
        .info-table .val {
            font-weight: 700;
            border-bottom: 1px solid #000;
            padding-left: 6px;
        }
        .info-table .val-right {
            font-weight: 700;
            border-bottom: 1px solid #000;
            text-align: left;
            padding-left: 6px;
        }

        /* ── Comments Section ── */
        .comments-section {
            margin-bottom: 20px;
        }
        .comments-section h3 {
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 8px;
        }
        .comments-section ol {
            margin: 0;
            padding-left: 22px;
            font-size: 11px;
        }
        .comments-section ol li {
            margin-bottom: 6px;
            padding-left: 4px;
        }
        .no-comments {
            font-style: italic;
            color: #666;
            margin-top: 10px;
        }

        /* ── Signatures ── */
        .signature-section {
            margin-top: 60px;
            font-size: 10px;
            display: flex;
            justify-content: flex-start;
            gap: 100px;
        }
        .sig-block {
            text-align: left;
        }
        .sig-label {
            margin-bottom: 30px;
        }
        .sig-name {
            font-weight: 700;
            font-size: 10px;
        }
        .sig-title {
            font-size: 9px;
        }

        /* ── Disclaimer ── */
        .disclaimer {
            margin-top: 30px;
            padding: 12px 0;
            font-size: 10px;
            line-height: 1.20;
        }
        .disclaimer strong { font-style: normal; }

        /* ── Footer Table ── */
        .doc-footer-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 60px;
            font-size: 9px;
        }
        .doc-footer-table td {
            border: 1px solid #000;
            padding: 3px 6px;
            vertical-align: middle;
        }
        .doc-footer-table .ft-lbl {
            font-weight: 700;
            white-space: nowrap;
            width: 22%;
        }
        .doc-footer-table .ft-val {
            width: 20%;
        }
        .doc-footer-table .ft-page {
            text-align: right;
            border: 1px solid #000;
            font-size: 10px;
            padding: 3px 10px;
            vertical-align: middle;
            white-space: nowrap;
        }

        /* ── Print-specific ── */
        @media print {
            body { padding: 0; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>

    {# ═══════════════════════════════════════════
       LETTERHEAD
       ═══════════════════════════════════════════ #}
    <div class="letterhead">
        <img src="{{ absolute_url(asset('images/header.jpg')) }}" alt="NORSU Letterhead">
    </div>

    {# ═══════════════════════════════════════════
       TITLE BLOCK
       ═══════════════════════════════════════════ #}
    <div class="title-block">
        <h1>Office of the Director, Quality Assurance Management Center</h1>
        <br>
        <h2>SUPERIOR EVALUATION FOR FACULTY — COMMENTS</h2>
    </div>

    {# ═══════════════════════════════════════════
       FACULTY INFO
       ═══════════════════════════════════════════ #}
    <table class="info-table">
        <tr>
            <td class="lbl">Name of Faculty:</td>
            <td class="val" style="width:38%">{{ faculty.lastName }}, {{ faculty.firstName }}</td>
            <td class="lbl">Position:</td>
            <td class="val-right">{{ evaluation.position ?? 'N/A' }}</td>
        </tr>
        <tr>
            <td class="lbl">College/Department:</td>
            <td class="val">{{ evaluation.college ?? (faculty.department ? faculty.department.collegeName : 'N/A') }}</td>
            <td class="lbl">Semester:</td>
            <td class="val-right">{{ evaluation.semester ?? current_academic_year().semester ?? '' }}</td>
        </tr>
        <tr>
            <td class="lbl">Campus:</td>
            <td class="val">{{ faculty.campus ?? 'N/A' }}</td>
            <td class="lbl">School Year:</td>
            <td class="val-right">{{ evaluation.schoolYear ?? '' }}</td>
        </tr>
    </table>

    {# ═══════════════════════════════════════════
       COMMENTS
       ═══════════════════════════════════════════ #}
    <div class="comments-section">
        <h3>Evaluator Comments — {{ printSubjectCode ?? 'SEF' }}{% if printSection %} ({{ printSection }}){% endif %} ({{ comments|length }})</h3>
        {% if comments|length > 0 %}
        <ol>
            {% for c in comments %}
                <li>{{ c }}</li>
            {% endfor %}
        </ol>
        {% else %}
        <p class="no-comments">No comments were submitted for this evaluation.</p>
        {% endif %}
    </div>

    {# ═══════════════════════════════════════════
       SIGNATURE SECTION
       ═══════════════════════════════════════════ #}
    <div class="signature-section">
        <div class="sig-block">
            <div class="sig-label">Prepared by:</div>
            <div class="sig-name">ARGIE PAIR PAGBUNOCAN</div>
            <div class="sig-title">QUAMC Staff</div>
        </div>
        <div class="sig-block">
            <div class="sig-label">Certified true and correct:</div>
            <div class="sig-name">CESAR P. ESTROPE, Ed.D.</div>
            <div class="sig-title">Director, Quality Assurance Management Center</div>
        </div>
    </div>

    {# ═══════════════════════════════════════════
       DISCLAIMER
       ═══════════════════════════════════════════ #}
    <div class="disclaimer">
        <strong><em>Disclaimer:</em></strong> <em>The information transmitted by this document is intended only for the person or entity to which it is
        addressed. This document may contain proprietary, business-confidential and/or privileged material. If you are not
        the intended recipient of this message, be aware that any use, review, retransmission, distribution, reproduction or
        any action taken in reliance upon this message is strictly prohibited. If you received this in error, please contact the
        sender. Thank you</em>
    </div>

    {# ═══════════════════════════════════════════
       DOCUMENT FOOTER
       ═══════════════════════════════════════════ #}
    <table class="doc-footer-table">
        <tr>
            <td class="ft-lbl">Correspondence ID</td>
            <td class="ft-val"></td>
            <td class="ft-lbl"></td>
            <td class="ft-val"></td>
            <td rowspan="3" class="ft-page">Page <strong>1</strong> of <strong>1</strong></td>
        </tr>
        <tr>
            <td class="ft-lbl">Issue Date</td>
            <td class="ft-val">{{ "now"|date("m-d-Y") }}</td>
            <td class="ft-lbl">Issue Status</td>
            <td class="ft-val"></td>
        </tr>
        <tr>
            <td class="ft-lbl">Reviewed &amp; authorized by</td>
            <td class="ft-val">ODQA</td>
            <td class="ft-lbl">Approved by</td>
            <td class="ft-val">ODQA</td>
        </tr>
    </table>

    {# Auto-trigger print dialog #}
    <script>
        window.addEventListener('load', function() {
            setTimeout(function() { window.print(); }, 400);
        });
    </script>
</body>
</html>

{% extends 'home/faculty/_layout.html.twig' %}

{% block header_color %}#1d4ed8,#3b82f6{% endblock %}
{% block header_icon %}calendar3{% endblock %}
{% block page_title %}Academic Year{% endblock %}
{% block page_subtitle %}View current academic year and your assigned subjects by semester{% endblock %}

{% block page_content %}

{# ── Current AY Spotlight ── #}
{% if currentAY %}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:#EFF6FF;color:#2563EB">
            <i class="bi bi-calendar-check-fill fs-4"></i>
        </div>
        <div class="flex-grow-1">
            <div class="fw-bold" style="font-size:1.05rem">{{ currentAY.label }}</div>
            {% if currentAY.startDate and currentAY.endDate %}
            <small class="text-muted"><i class="bi bi-calendar-range me-1"></i>{{ currentAY.startDate|date('M d, Y') }} — {{ currentAY.endDate|date('M d, Y') }}</small>
            {% endif %}
        </div>
        <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body text-center py-4 text-muted">
        <i class="bi bi-exclamation-triangle fs-3 d-block mb-2 text-warning"></i>
        <p class="mb-0">No active academic year set.</p>
    </div>
</div>
{% endif %}

{# ── Semester Stats ── #}
<div class="row g-3 mb-4">
    {% for sem, subjects in bySemester %}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="fw-bold fs-3 text-primary">{{ subjects|length }}</div>
                <div class="text-muted" style="font-size:.85rem">{{ sem }}</div>
            </div>
        </div>
    </div>
    {% endfor %}
    {% if bySemester|length == 0 %}
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-3 text-muted" style="font-size:.85rem">No assigned subjects found.</div>
        </div>
    </div>
    {% endif %}
</div>

{# ── Semester Filter Tabs ── #}
{% set semesters = bySemester|keys %}
<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <button class="btn btn-sm btn-primary ay-sem-tab active" data-sem="all" onclick="ayFilterSem('all', this)">
        All <span class="badge bg-white text-primary ms-1">{{ loadedSubjects|length }}</span>
    </button>
    {% for sem in semesters %}
    <button class="btn btn-sm btn-outline-primary ay-sem-tab" data-sem="{{ sem }}" onclick="ayFilterSem('{{ sem }}', this)">
        {{ sem }} <span class="badge bg-primary bg-opacity-10 text-primary ms-1">{{ bySemester[sem]|length }}</span>
    </button>
    {% endfor %}
    <div class="ms-auto position-relative">
        <i class="bi bi-search position-absolute" style="left:10px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.8rem"></i>
        <input type="text" id="aySubSearch" class="form-control form-control-sm" placeholder="Search subjects..." style="padding-left:32px;border-radius:8px;border:1px solid #e2e8f0;font-size:.82rem;width:200px" oninput="aySearch()">
    </div>
</div>

{# ── Subjects Table ── #}
{% if loadedSubjects|length > 0 %}
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="background:#f8fafc">
                        <th class="ps-3" style="width:40px;font-size:.78rem;color:#64748b;font-weight:600">#</th>
                        <th style="font-size:.78rem;color:#64748b;font-weight:600">Code</th>
                        <th style="font-size:.78rem;color:#64748b;font-weight:600">Subject Name</th>
                        <th style="font-size:.78rem;color:#64748b;font-weight:600">Semester</th>
                        <th style="font-size:.78rem;color:#64748b;font-weight:600">Year Level</th>
                        <th class="text-center" style="font-size:.78rem;color:#64748b;font-weight:600">Units</th>
                    </tr>
                </thead>
                <tbody id="aySubBody">
                    {% set idx = 0 %}
                    {% for sem, subjects in bySemester %}
                        {% for s in subjects %}
                        {% set idx = idx + 1 %}
                        <tr class="ay-sub-row" data-sem="{{ sem }}" data-search="{{ s.subjectCode|lower }} {{ s.subjectName|lower }}">
                            <td class="ps-3 text-muted" style="font-size:.85rem">{{ idx }}</td>
                            <td><span class="fw-semibold" style="color:#1e40af;font-size:.88rem">{{ s.subjectCode }}</span></td>
                            <td style="font-size:.88rem">{{ s.subjectName }}</td>
                            <td>
                                {% if s.semester %}
                                <span class="badge {% if '1st' in s.semester %}bg-primary{% elseif '2nd' in s.semester %}bg-info{% elseif 'Summer' in s.semester %}bg-warning text-dark{% else %}bg-secondary{% endif %} bg-opacity-10 
                                {% if '1st' in s.semester %}text-primary{% elseif '2nd' in s.semester %}text-info{% elseif 'Summer' in s.semester %}text-warning{% else %}text-secondary{% endif %} px-2 py-1">
                                    {{ s.semester }}
                                </span>
                                {% else %}
                                <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td style="font-size:.85rem">{{ s.yearLevel|default('—') }}</td>
                            <td class="text-center" style="font-size:.85rem">{{ s.units|default('—') }}</td>
                        </tr>
                        {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5 text-muted">
        <i class="bi bi-book fs-1 d-block mb-2"></i>
        <p class="mb-0">No assigned subjects yet.</p>
    </div>
</div>
{% endif %}

{# ── All Academic Years ── #}
<div class="mt-4">
    <h6 class="fw-semibold mb-3"><i class="bi bi-clock-history text-muted me-1"></i>All Academic Years</h6>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr style="background:#f8fafc">
                            <th class="ps-3" style="font-size:.78rem;color:#64748b;font-weight:600">Academic Year</th>
                            <th style="font-size:.78rem;color:#64748b;font-weight:600">Semester</th>
                            <th style="font-size:.78rem;color:#64748b;font-weight:600">Date Range</th>
                            <th class="text-center" style="font-size:.78rem;color:#64748b;font-weight:600">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ay in academicYears %}
                        <tr>
                            <td class="ps-3 fw-semibold" style="font-size:.88rem">{{ ay.yearLabel }}</td>
                            <td style="font-size:.85rem">{{ ay.semester|default('—') }}</td>
                            <td style="font-size:.85rem">
                                {% if ay.startDate and ay.endDate %}
                                    {{ ay.startDate|date('M d, Y') }} — {{ ay.endDate|date('M d, Y') }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if ay.isCurrent %}
                                    <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                {% else %}
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-2 py-1">Inactive</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
function ayFilterSem(sem, btn) {
    document.querySelectorAll('.ay-sem-tab').forEach(b => {
        b.classList.remove('active','btn-primary');
        b.classList.add('btn-outline-primary');
    });
    btn.classList.remove('btn-outline-primary');
    btn.classList.add('active','btn-primary');

    document.querySelectorAll('.ay-sub-row').forEach(r => {
        r.style.display = (sem === 'all' || r.dataset.sem === sem) ? '' : 'none';
    });
    reindex();
}

function aySearch() {
    const q = document.getElementById('aySubSearch').value.trim().toLowerCase();
    document.querySelectorAll('.ay-sub-row').forEach(r => {
        if (r.style.display === 'none' && !r.dataset.search.includes(q)) return;
        const semMatch = r.style.display !== 'none' || document.querySelector('.ay-sem-tab.active').dataset.sem === 'all' || r.dataset.sem === document.querySelector('.ay-sem-tab.active').dataset.sem;
        r.style.display = (r.dataset.search.includes(q) && semMatch) ? '' : 'none';
    });
    reindex();
}

function reindex() {
    let i = 0;
    document.querySelectorAll('.ay-sub-row').forEach(r => {
        if (r.style.display !== 'none') {
            i++;
            r.querySelector('td').textContent = i;
        }
    });
}
</script>
{% endblock %}

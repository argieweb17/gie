{% extends 'base.html.twig' %}

{% block title %}Evaluation Summary | SET-SEF Evaluation{% endblock %}

{% block stylesheets %}
<style>
/* ── Header ── */
.sm-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 4px 24px rgba(26,86,219,.15);margin-bottom:16px;padding:1.3rem 1.8rem;position:relative;}
.sm-header::before{content:'';position:absolute;top:-40%;right:-10%;width:260px;height:260px;background:radial-gradient(circle,rgba(255,255,255,.06) 0%,transparent 70%);border-radius:50%;}
.sm-header-inner{display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;flex-wrap:wrap;gap:1rem;}
.sm-header-icon{width:44px;height:44px;border-radius:.75rem;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:1.25rem;color:#fff;backdrop-filter:blur(4px);}
.sm-meta-pill{background:rgba(255,255,255,.12);padding:.2rem .65rem;border-radius:1rem;color:rgba(255,255,255,.85);font-weight:500;backdrop-filter:blur(4px);}
.sm-stats-row{display:flex;align-items:center;gap:1.2rem;}
.sm-stat{text-align:center;}
.sm-stat-val{display:block;font-size:1.1rem;font-weight:800;color:#fff;}
.sm-stat-lbl{font-size:.65rem;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:.04em;font-weight:600;}

/* ── Restricted Card ── */
.sm-restricted-wrap{display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 260px);padding:2rem 1rem;}
.sm-restricted-card{text-align:center;max-width:460px;width:100%;padding:2.8rem 2.2rem 2.2rem;background:#fff;border:1px solid #e8ecf1;border-radius:1.1rem;box-shadow:0 4px 28px rgba(0,0,0,.06);animation:smFadeUp .5s ease;}
.sm-restricted-badge{margin-bottom:1.5rem;}
.sm-restricted-icon-ring{width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#FEF2F2,#FEE2E2);display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:2rem;color:#EF4444;box-shadow:0 4px 16px rgba(239,68,68,.12);position:relative;}
.sm-restricted-icon-ring::after{content:'';position:absolute;inset:-4px;border-radius:50%;border:2px dashed rgba(239,68,68,.2);}
.sm-restricted-title{font-size:1.3rem;font-weight:700;color:#1E293B;margin-bottom:.6rem;}
.sm-restricted-desc{font-size:.88rem;color:#64748B;line-height:1.65;margin-bottom:1.25rem;max-width:380px;margin-left:auto;margin-right:auto;}
.sm-restricted-info{background:#F8FAFC;border:1px solid #E2E8F0;border-radius:.75rem;padding:.85rem 1rem;margin-bottom:1.5rem;text-align:left;}
.sm-info-item{display:flex;align-items:flex-start;gap:.5rem;font-size:.82rem;color:#475569;}
.sm-info-item i{color:#3B82F6;margin-top:.1rem;flex-shrink:0;}
.sm-restricted-btn{display:inline-flex;align-items:center;padding:.65rem 1.6rem;border-radius:.625rem;background:linear-gradient(135deg,#1E3A8A,#1E40AF 50%,#059669);color:#fff;font-size:.85rem;font-weight:600;text-decoration:none;transition:all .25s;box-shadow:0 2px 8px rgba(30,64,175,.2);}
.sm-restricted-btn:hover{box-shadow:0 6px 20px rgba(30,64,175,.35);transform:translateY(-2px);color:#fff;}

@keyframes smFadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

@media(max-width:576px){
    .sm-header{padding:1rem 1.2rem;}
    .sm-restricted-card{padding:2rem 1.2rem 1.5rem;}
    .sm-restricted-title{font-size:1.15rem;}
}
</style>
{% endblock %}

{% block body %}

{# ── Gradient Header Card ── #}
<div class="sm-header">
    <div class="sm-header-inner">
        <div class="d-flex align-items-center gap-3">
            <div class="sm-header-icon"><i class="bi bi-file-earmark-bar-graph-fill"></i></div>
            <div>
                <h5 class="mb-0 text-white fw-bold" style="font-size:1.1rem;">Evaluation Summary</h5>
                <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                    <span class="sm-meta-pill" style="font-size:.72rem;"><i class="bi bi-bar-chart-line me-1"></i>Overall evaluation statistics</span>
                </div>
            </div>
        </div>
        <div class="sm-stats-row">
            <div class="sm-stat">
                <span class="sm-stat-val"><i class="bi bi-lock-fill"></i></span>
                <span class="sm-stat-lbl">Restricted</span>
            </div>
        </div>
    </div>
</div>

{# ── Restricted Access Card ── #}
<div class="sm-restricted-wrap">
    <div class="sm-restricted-card">
        <div class="sm-restricted-badge">
            <div class="sm-restricted-icon-ring">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
        </div>
        <h4 class="sm-restricted-title">Feature Not Available</h4>
        <p class="sm-restricted-desc">The Evaluation Summary feature is currently restricted. Please contact your administrator or department head for access to this module.</p>
        <div class="sm-restricted-info">
            <div class="sm-info-item">
                <i class="bi bi-info-circle-fill"></i>
                <span>This module provides overall evaluation statistics and performance summaries.</span>
            </div>
        </div>
        <a href="{{ path('app_dashboard') }}" class="sm-restricted-btn">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>
</div>

{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Data Migration | SET-SEF Evaluation{% endblock %}

{% block body %}
{# ── Header ── #}
<div class="mg-header">
    <div class="mg-header-inner">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="mg-header-icon"><i class="bi bi-database-fill-gear"></i></div>
                <div>
                    <h4 class="fw-bold mb-1 text-white" style="font-size:1.25rem;">Data Migration</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center" style="font-size:.78rem;">
                        <span class="mg-meta-pill"><i class="bi bi-people me-1"></i>{{ totalUsers }} Total Users</span>
                        <span class="mg-meta-pill"><i class="bi bi-calendar3 me-1"></i>{{ 'now'|date('M d, Y') }}</span>
                    </div>
                </div>
            </div>
            <a href="{{ path('admin_users') }}" class="btn btn-sm btn-outline-light fw-semibold">
                <i class="bi bi-arrow-left me-1"></i>Back to Users
            </a>
        </div>
        <div class="mg-stats-row">
            <div class="mg-stat">
                <span class="mg-stat-val">{{ studentCount }}</span>
                <span class="mg-stat-lbl">Students</span>
            </div>
            <div class="mg-stat-divider"></div>
            <div class="mg-stat">
                <span class="mg-stat-val">{{ facultyCount }}</span>
                <span class="mg-stat-lbl">Faculty</span>
            </div>
            <div class="mg-stat-divider"></div>
            <div class="mg-stat">
                <span class="mg-stat-val">{{ staffCount }}</span>
                <span class="mg-stat-lbl">Staff</span>
            </div>
            <div class="mg-stat-divider"></div>
            <div class="mg-stat">
                <span class="mg-stat-val">{{ adminCount }}</span>
                <span class="mg-stat-lbl">Admins</span>
            </div>
            <div class="mg-stat-divider"></div>
            <div class="mg-stat">
                <span class="mg-stat-val">{{ totalUsers }}</span>
                <span class="mg-stat-lbl">Total</span>
            </div>
        </div>
    </div>
</div>

{# ── Import Section ── #}
<div class="mg-section-card">
    <div class="mg-section-header" style="background:linear-gradient(135deg,#059669,#10b981 60%,#34d399);">
        <span><i class="bi bi-cloud-arrow-up-fill me-2"></i>Import Users (CSV)</span>
    </div>
    <div class="p-4">
        <form method="post" action="{{ path('admin_migration_import') }}" enctype="multipart/form-data">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold small text-muted"><i class="bi bi-people me-1"></i>Target Role</label>
                    <select name="target_role" class="form-select form-select-sm" required>
                        <option value="student">Student</option>
                        <option value="faculty">Faculty</option>
                        <option value="staff">Staff</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold small text-muted"><i class="bi bi-file-earmark-spreadsheet me-1"></i>CSV File</label>
                    <input type="file" name="csv_file" class="form-control form-control-sm" accept=".csv" required>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-sm btn-norsu w-100">
                        <i class="bi bi-cloud-arrow-up me-1"></i>Import
                    </button>
                </div>
            </div>
            <div class="mt-3 p-3 rounded" style="background:#f0fdf4;border:1px solid #bbf7d0;">
                <p class="small fw-semibold text-success mb-2"><i class="bi bi-info-circle me-1"></i>CSV Format Guide</p>
                <p class="small text-muted mb-1">Required columns: <code>FirstName</code>, <code>LastName</code>, <code>Email</code></p>
                <p class="small text-muted mb-1">Optional columns: <code>Department</code>, <code>SchoolID</code>, <code>Campus</code>, <code>Password</code></p>
                <p class="small text-muted mb-1">Student-only: <code>YearLevel</code>, <code>Course</code></p>
                <p class="small text-muted mb-0">Faculty/Staff: <code>EmploymentStatus</code></p>
                <p class="small text-muted mt-2 mb-0"><i class="bi bi-shield-check me-1"></i>Duplicate emails will be automatically skipped. Default password: <code>password123</code></p>
            </div>
        </form>
    </div>
</div>

{# ── Export Section ── #}
<div class="mg-section-card">
    <div class="mg-section-header" style="background:linear-gradient(135deg,#1d4ed8,#3b82f6 60%,#60a5fa);">
        <span><i class="bi bi-cloud-arrow-down-fill me-2"></i>Export Users (CSV)</span>
    </div>
    <div class="p-4">
        <p class="small text-muted mb-3">Download existing user data as CSV files, grouped by role. Useful for backup or transferring data.</p>
        <div class="row g-3">
            <div class="col-md-3">
                <a href="{{ path('admin_migration_export', {role: 'student'}) }}" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-backpack-fill me-1"></i>Export Students
                    <span class="badge bg-primary ms-1">{{ studentCount }}</span>
                </a>
            </div>
            <div class="col-md-3">
                <a href="{{ path('admin_migration_export', {role: 'faculty'}) }}" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-mortarboard-fill me-1"></i>Export Faculty
                    <span class="badge bg-primary ms-1">{{ facultyCount }}</span>
                </a>
            </div>
            <div class="col-md-3">
                <a href="{{ path('admin_migration_export', {role: 'staff'}) }}" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-clipboard-data me-1"></i>Export Staff
                    <span class="badge bg-primary ms-1">{{ staffCount }}</span>
                </a>
            </div>
            <div class="col-md-3">
                <a href="{{ path('admin_migration_export', {role: 'admin'}) }}" class="btn btn-outline-primary btn-sm w-100">
                    <i class="bi bi-shield-fill me-1"></i>Export Admins
                    <span class="badge bg-primary ms-1">{{ adminCount }}</span>
                </a>
            </div>
        </div>
    </div>
</div>

{# ── Quick Overview Cards ── #}
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="mg-overview-card">
            <div class="mg-ov-icon" style="background:#f3e8ff;color:#7c3aed;"><i class="bi bi-backpack-fill"></i></div>
            <div>
                <div class="mg-ov-val">{{ studentCount }}</div>
                <div class="mg-ov-lbl">Students</div>
            </div>
            <a href="{{ path('admin_students') }}" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mg-overview-card">
            <div class="mg-ov-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="bi bi-mortarboard-fill"></i></div>
            <div>
                <div class="mg-ov-val">{{ facultyCount }}</div>
                <div class="mg-ov-lbl">Faculty</div>
            </div>
            <a href="{{ path('admin_faculty_list') }}" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mg-overview-card">
            <div class="mg-ov-icon" style="background:#dcfce7;color:#15803d;"><i class="bi bi-clipboard-data"></i></div>
            <div>
                <div class="mg-ov-val">{{ staffCount }}</div>
                <div class="mg-ov-lbl">Staff</div>
            </div>
            <a href="{{ path('admin_staff_list') }}" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mg-overview-card">
            <div class="mg-ov-icon" style="background:#fce7f3;color:#be185d;"><i class="bi bi-shield-fill"></i></div>
            <div>
                <div class="mg-ov-val">{{ adminCount }}</div>
                <div class="mg-ov-lbl">Admins</div>
            </div>
            <a href="{{ path('admin_admin_list') }}" class="stretched-link"></a>
        </div>
    </div>
</div>

{# ═══════ STYLES ═══════ #}
<style>
.mg-header{border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,rgba(30,58,138,.95),rgba(30,64,175,.9) 50%,rgba(5,150,105,.85) 100%);box-shadow:0 10px 40px rgba(30,58,138,.18);margin-bottom:1.5rem;position:relative;}
.mg-header::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E") repeat;pointer-events:none;}
.mg-header-inner{position:relative;z-index:1;padding:1.5rem 1.75rem 1.25rem;}
.mg-header-icon{width:48px;height:48px;background:rgba(255,255,255,.15);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.35rem;color:#fff;backdrop-filter:blur(4px);flex-shrink:0;}
.mg-meta-pill{background:rgba(255,255,255,.13);color:rgba(255,255,255,.9);padding:2px 10px;border-radius:20px;font-size:.75rem;backdrop-filter:blur(4px);}
.mg-stats-row{display:flex;gap:.5rem;margin-top:1.1rem;padding-top:.9rem;border-top:1px solid rgba(255,255,255,.13);flex-wrap:wrap;}
.mg-stat{text-align:center;flex:1;min-width:70px;}
.mg-stat-val{display:block;font-size:1.3rem;font-weight:700;color:#fff;line-height:1.2;}
.mg-stat-lbl{display:block;font-size:.65rem;color:rgba(255,255,255,.7);text-transform:uppercase;letter-spacing:.5px;margin-top:2px;}
.mg-stat-divider{width:1px;background:rgba(255,255,255,.15);align-self:stretch;margin:0 .25rem;}
.mg-section-card{background:#fff;border:1px solid #e5e7eb;border-radius:.75rem;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04);margin-bottom:1.25rem;}
.mg-section-header{color:#fff;padding:.65rem 1.1rem;font-size:.85rem;font-weight:600;}
.mg-overview-card{position:relative;background:#fff;border:1px solid #e5e7eb;border-radius:.75rem;padding:1.25rem;display:flex;align-items:center;gap:1rem;box-shadow:0 1px 3px rgba(0,0,0,.04);transition:all .2s;}
.mg-overview-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.08);transform:translateY(-2px);}
.mg-ov-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
.mg-ov-val{font-size:1.5rem;font-weight:700;color:#1e293b;line-height:1.2;}
.mg-ov-lbl{font-size:.72rem;color:#64748b;text-transform:uppercase;letter-spacing:.5px;}
@keyframes mgFadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.mg-section-card,.mg-overview-card{animation:mgFadeIn .25s ease;}
</style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}My Profile | SET-SEF Evaluation{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i  class="me-2" data-lucide="circle-user"></i>My Profile</h4>
    <div class="page-header-actions">
        <a href="{{ path('app_profile_edit') }}" class="btn btn-norsu btn-sm">
            <i  data-lucide="pencil-line"></i> Edit Profile
        </a>
    </div>
</div>

<div class="row g-4">
    {# ── Profile Card ── #}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-5">
                <img src="{{ asset('images/' ~ user.profilePictureOrDefault) }}"
                     alt="{{ user.fullName }}" class="rounded-circle mb-3"
                     style="width:90px;height:90px;object-fit:cover">
                <h5 class="fw-bold mb-1">{{ user.fullName }}</h5>
                <p class="text-muted mb-2">{{ user.email }}</p>
                {% if 'ROLE_ADMIN' in user.roles %}
                    <span class="badge bg-danger"><i  class="me-1" data-lucide="shield-check"></i>Administrator</span>
                {% elseif user.hasAssignedRole('ROLE_SUPERIOR') %}
                    <span class="badge bg-primary"><i  class="me-1" data-lucide="star"></i>Superior</span>
                {% elseif 'ROLE_FACULTY' in user.roles %}
                    <span class="badge bg-warning text-dark"><i  class="me-1" data-lucide="graduation-cap"></i>Faculty</span>
                {% elseif 'ROLE_STAFF' in user.roles %}
                    <span class="badge bg-info"><i  class="me-1" data-lucide="clipboard-list"></i>Staff</span>
                {% else %}
                    <span class="badge bg-primary"><i  class="me-1" data-lucide="user"></i>Student</span>
                {% endif %}

                {# Upload Picture #}
                <form method="post" action="{{ path('app_profile_upload_picture') }}" enctype="multipart/form-data" class="mt-3">
                    <input type="file" name="profilePicture" accept="image/*" class="form-control form-control-sm mb-2">
                    <button type="submit" class="btn btn-outline-norsu btn-sm w-100">
                        <i  class="me-1" data-lucide="camera"></i>Update Photo
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ── Account Details ── #}
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold"><i  class="me-1" data-lucide="info"></i> Account Information</div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tbody>
                        {% set _is_assigned_superior = user.hasAssignedRole('ROLE_SUPERIOR') %}
                        <tr>
                            <td class="text-muted" style="width:200px"><i  class="me-2" data-lucide="user"></i>First Name</td>
                            <td class="fw-semibold">{{ user.firstName }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="user"></i>Last Name</td>
                            <td class="fw-semibold">{{ user.lastName }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="mail"></i>Email Address</td>
                            <td class="fw-semibold">{{ user.email }}</td>
                        </tr>
                        {% if 'ROLE_STAFF' not in user.roles and not _is_assigned_superior %}
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="building-2"></i>Department</td>
                            <td class="fw-semibold">{{ user.department ? user.department.departmentName : '—' }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="landmark"></i>College</td>
                            <td class="fw-semibold">{{ user.department and user.department.collegeName ? user.department.collegeName : '—' }}</td>
                        </tr>
                        {% endif %}
                        {% if 'ROLE_STAFF' not in user.roles %}
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="map-pin"></i>Campus</td>
                            <td class="fw-semibold">{{ user.campus ?? '—' }}</td>
                        </tr>
                        {% endif %}
                        {% if _is_assigned_superior %}
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="briefcase"></i>Position / Designation</td>
                            <td class="fw-semibold">{{ user.position ?? '—' }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="award"></i>Academic Rank</td>
                            <td class="fw-semibold">{{ user.academicRank ?? '—' }}</td>
                        </tr>
                        {% endif %}
                        {% if user.isStudent %}
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="id-card"></i>Student ID</td>
                            <td class="fw-semibold">{{ user.schoolId ?? '—' }}</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="graduation-cap"></i>Year Level</td>
                            <td class="fw-semibold">{{ user.yearLevel ?? '—' }}</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="shield"></i>Role</td>
                            <td>
                                {% if 'ROLE_ADMIN' in user.roles %}
                                    <span class="badge bg-danger me-1">Admin</span>
                                {% endif %}
                                {% if user.hasAssignedRole('ROLE_SUPERIOR') %}
                                    <span class="badge bg-primary me-1">Superior</span>
                                {% endif %}
                                {% if 'ROLE_FACULTY' in user.roles %}
                                    <span class="badge bg-warning text-dark me-1">Faculty</span>
                                {% endif %}
                                {% if 'ROLE_STAFF' in user.roles %}
                                    <span class="badge bg-info me-1">Staff</span>
                                {% endif %}
                                {% if not ('ROLE_ADMIN' in user.roles or 'ROLE_FACULTY' in user.roles or 'ROLE_STAFF' in user.roles) %}
                                    <span class="badge bg-primary me-1">Student</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="circle-check"></i>Account Status</td>
                            <td>
                                {% if user.accountStatus == 'active' %}
                                    <span class="badge bg-success">Active</span>
                                {% else %}
                                    <span class="badge bg-secondary">Inactive</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i  class="me-2" data-lucide="calendar-days"></i>Registered</td>
                            <td class="fw-semibold">{{ user.createdAt|date('F d, Y \\a\\t h:i A') }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        {# ── Security Section ── #}
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-white fw-semibold"><i  class="me-1" data-lucide="lock"></i> Security</div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 fw-semibold">Password</p>
                        <p class="text-muted mb-0 small">Update your password regularly for security.</p>
                    </div>
                    <a href="{{ path('app_profile_change_password') }}" class="btn btn-outline-norsu btn-sm">
                        <i  class="me-1" data-lucide="key"></i>Change Password
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
